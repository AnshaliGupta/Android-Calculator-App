<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">
    
    <EditText
        android:id="@+id/main_entry_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:background="@null"
        android:gravity="end"
        android:textAlignment="viewEnd"

        android:inputType="textMultiLine"
        android:cursorVisible="true"

        android:minLines="1"
        android:maxLines="3"

        android:autoSizeTextType="uniform"
        android:autoSizeMaxTextSize="45sp"
        android:autoSizeMinTextSize="18sp"
        android:autoSizeStepGranularity="1sp"

        android:scrollbars="vertical"
        android:overScrollMode="always"

        android:padding="16dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"

        android:textColor="@color/textColor"
        android:textSize="45sp"
        tools:text="9999999999*4556787877"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.044"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/answer_text"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:autoSizeMaxTextSize="30sp"
        android:autoSizeMinTextSize="5sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:padding="9dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="21dp"
        android:text=""
        android:textAlignment="viewEnd"
        android:textColor="@color/secondaryText"
        android:textSize="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/main_entry_text"
        app:layout_constraintVertical_bias="0.028"
        tools:layout_editor_absoluteX="0dp"
        tools:targetApi="o"/>

    <ImageButton
        android:id="@+id/history_button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="History"
        android:padding="-15dp"
        android:src="@drawable/history_button_img"
        app:layout_constraintBottom_toTopOf="@+id/view"
        app:layout_constraintEnd_toStartOf="@+id/del_button"
        app:layout_constraintHorizontal_bias="0.057"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/answer_text"
        app:layout_constraintVertical_bias="0.0" />

    <ImageButton
        android:id="@+id/del_button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Backspace"
        android:padding="5dp"
        android:src="@drawable/backspace_button_img"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/answer_text" />

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_margin="15dp"
        android:background="@color/dividerColor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/del_button"
        app:layout_constraintVertical_bias="0.0"
        tools:layout_editor_absoluteX="9dp" />

    <LinearLayout
        android:id="@+id/history_layout"
        android:layout_width="285dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="12dp"
        android:elevation="12dp"
        app:layout_constraintTop_toBottomOf="@+id/view"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="20dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/history_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:verticalScrollbarPosition="right"
            android:layout_marginBottom="15dp"
            android:paddingEnd="8dp"/>

        <Button
            android:id="@+id/clear_history"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/clear_history"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/textColor"
            android:background="@drawable/bg_history_button"/>

    </LinearLayout>

    <GridLayout
        android:id="@+id/grid_layout"
        android:layout_width="380dp"
        android:layout_height="420dp"
        android:layout_margin="15dp"
        android:alignmentMode="alignBounds"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view"
        app:layout_constraintVertical_bias="0.0"
        tools:layout_editor_absoluteX="15dp">

        <Button
            android:id="@+id/clear_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="C"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/bracket_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="( )"
            android:textColor="@color/textColor"
            android:textSize="30sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/percentage_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="%"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/divide_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="÷"
            android:textColor="@color/colorBackground"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_7"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="7"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_8"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="8"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_9"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="9"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/multiply_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="×"
            android:textColor="@color/colorBackground"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:text="5"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="6"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/subtract_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="−"
            android:textColor="@color/colorBackground"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/plus_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/colorBackground"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/sign_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="+/-"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_0"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/dec_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="."
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/equals_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_equals_button"
            android:gravity="center"
            android:text="="
            android:textColor="@color/colorBackground"
            android:textSize="35sp"
            app:backgroundTint="@null" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>