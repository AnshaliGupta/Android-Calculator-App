<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/frame_layout"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/main_entry_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:background="@null"
            android:cursorVisible="true"
            android:gravity="end|bottom"

            android:inputType="textMultiLine"
            android:minLines="1"
            android:maxLines="3"

            android:scrollbars="vertical"
            android:overScrollMode="never"

            android:textSize="45sp"
            android:textColor="@color/textColor"
            android:padding="16dp"
            android:textAlignment="viewEnd"
            tools:text="99999999*45000000222"/>

    </FrameLayout>

    <TextView
        android:id="@+id/answer_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:autoSizeMaxTextSize="30sp"
        android:autoSizeMinTextSize="5sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:padding="9dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="21dp"
        android:layout_marginTop="17dp"
        android:text=""
        android:textAlignment="viewEnd"
        android:textColor="@color/secondaryText"
        android:textSize="30sp"
        app:layout_constraintTop_toBottomOf="@+id/frame_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout_editor_absoluteX="0dp"
        tools:targetApi="o"/>

    <ImageButton
        android:id="@+id/history_button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="15dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/history"
        android:padding="-15dp"
        android:src="@drawable/history_button_img"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/answer_text" />

    <ImageButton
        android:id="@+id/del_button"
        android:layout_width="60dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/backspace"
        android:padding="5dp"
        android:src="@drawable/backspace_button_img"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/answer_text" />

    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="10dp"
        android:background="@color/dividerColor"

        app:layout_constraintTop_toBottomOf="@id/del_button"
        app:layout_constraintBottom_toTopOf="@id/grid_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/history_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:visibility="gone"
        android:elevation="12dp"
        android:background="@color/colorBackground"
        android:padding="12dp"

        android:layout_marginStart="15dp"
        android:layout_marginEnd="90dp"
        android:layout_marginBottom="20dp"

        android:maxHeight="350dp"

        app:layout_constraintTop_toBottomOf="@id/view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/history_recycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scrollbars="vertical"

            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/clear_history"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Clear Button -->
        <Button
            android:id="@+id/clear_history"
            android:layout_width="0dp"
            android:layout_height="60dp"

            android:text="@string/clear_history"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/textColor"
            android:background="@drawable/bg_history_button"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <GridLayout
        android:id="@+id/grid_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="15dp"

        android:alignmentMode="alignBounds"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="5dp"
        android:useDefaultMargins="true"

        app:layout_constraintTop_toBottomOf="@id/view"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/clear_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="@string/c"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/bracket_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="@string/small_brackets"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/percentage_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator1_button"
            android:text="@string/percent"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/divide_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="@string/divide"
            android:textColor="@color/colorBackground"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_7"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_7"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_8"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_8"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_9"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_9"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/multiply_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="@string/multiply"
            android:textColor="@color/colorBackground"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_4"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:text="@string/_5"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_6"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/subtract_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="@string/subtract"
            android:textColor="@color/colorBackground"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_1"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_2"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_3"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/plus_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_operator2_button"
            android:gravity="center"
            android:text="@string/add"
            android:textColor="@color/colorBackground"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/sign_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/sign"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/button_0"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/_0"
            android:textColor="@color/textColor"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/dec_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_main_buttons"
            android:gravity="center"
            android:text="@string/decimal"
            android:textColor="@color/textColor"
            android:textSize="35sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/equals_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_equals_button"
            android:gravity="center"
            android:text="@string/equals"
            android:textColor="@color/colorBackground"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="35sp"
            app:autoSizeStepGranularity="2sp"
            app:backgroundTint="@null" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>